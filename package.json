{
  "name": "policy-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "SaferAI policy-team news tracker: weekly legislative, newsletter, and paper digests generated by Claude Code Routines and served as a static site.",
  "type": "module",
  "scripts": {
    "validate:sources": "bun run scripts/validate-sources.ts",
    "validate:content": "bun run scripts/validate-content.ts",
    "verify:rss": "bun run scripts/verify-rss.ts",
    "email:preview": "bun run scripts/send-digest-email.ts --dry-run",
    "slack:preview": "bun run scripts/send-digest-slack.ts --dry-run",
    "test": "bun run validate:sources && bun run validate:content",
    "site:dev": "cd site && bun run dev",
    "site:build": "cd site && bun run build",
    "site:preview": "cd site && bun run preview"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "nodemailer": "^7.0.5",
    "typescript": "^5.4.0",
    "yaml": "^2.4.0",
    "zod": "^3.22.0",
    "gray-matter": "^4.0.3"
  }
}
