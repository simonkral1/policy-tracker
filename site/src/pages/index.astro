---
import BaseLayout from "../layouts/BaseLayout.astro";
import DigestCard from "../components/DigestCard.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const base = import.meta.env.BASE_URL || "/";
function withBase(path: string): string {
  const b = base.endsWith("/") ? base.slice(0, -1) : base;
  const p = path.startsWith("/") ? path : `/${path}`;
  return `${b}${p}` || "/";
}

const [legislative, newsletter, papers] = await Promise.all([
  getCollection("legislative"),
  getCollection("newsletter"),
  getCollection("papers"),
]);

function byDateDesc<T extends { data: { date: Date } }>(a: T, b: T): number {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
}

const sortedLegislative = [...legislative].sort(byDateDesc);
const sortedNewsletter = [...newsletter].sort(byDateDesc);
const sortedPapers = [...papers].sort(byDateDesc);

const latestLegislative = sortedLegislative[0];
const latestNewsletter = sortedNewsletter[0];
const latestPapers = sortedPapers[0];

// Pull up to three item titles from the most recent legislative digest.
// Preference order: ACT NOW → ON THE RADAR → PIPELINE WATCH. Stops at 3.
function extractTopThree(
  entry: CollectionEntry<"legislative"> | undefined,
): string[] {
  if (!entry?.body) return [];

  const body = entry.body;
  const sectionOrder: RegExp[] = [
    /^##\s*(?:🔴\s*)?ACT\s*NOW\s*$/im,
    /^##\s*(?:🟡\s*)?ON\s*THE\s*RADAR\s*$/im,
    /^##\s*(?:🟢\s*)?PIPELINE\s*WATCH\s*$/im,
  ];

  const titles: string[] = [];
  for (const re of sectionOrder) {
    if (titles.length >= 3) break;
    const parts = body.split(re);
    if (parts.length < 2) continue;
    const after = parts[1];
    const nextHeadingIdx = after.search(/^##\s+/m);
    const section = nextHeadingIdx === -1 ? after : after.slice(0, nextHeadingIdx);
    const headingRe = /^###\s+(.+?)\s*$/gm;
    let m: RegExpExecArray | null;
    while ((m = headingRe.exec(section)) !== null && titles.length < 3) {
      titles.push(
        m[1]
          .replace(/[🔴🟡🟢📅💡📚📖🔗🔇🆕]/gu, "")
          .replace(/\bNEW\b/g, "")
          .replace(/\(follow-up[^)]*\)/gi, "")
          .replace(/\(was:[^)]*\)/gi, "")
          .replace(/\s+/g, " ")
          .trim(),
      );
    }
  }
  return titles;
}

const topThree = extractTopThree(latestLegislative);
const fallbackNote = latestLegislative?.data.editor_note ?? null;
const hasAnyDigest = Boolean(latestLegislative || latestNewsletter || latestPapers);

const latestCards = [latestLegislative, latestNewsletter, latestPapers].filter(
  Boolean,
) as Array<CollectionEntry<"legislative"> | CollectionEntry<"newsletter"> | CollectionEntry<"papers">>;
---

<BaseLayout title="SaferAI Policy Tracker" description="Weekly digests of global AI-policy activity, curated by SaferAI.">
  <section class="hero">
    <div class="masthead"><span class="issue-tag">Policy Tracker <strong>V 1.0</strong></span></div>
    <div class="kicker">SaferAI · Weekly</div>
    <h1>Policy Tracker</h1>
    <p class="tagline">
      Weekly reading on legislative, research, and newsletter signals in global
      AI policy — curated by the SaferAI policy team.
    </p>
  </section>

  <section aria-labelledby="top-three-heading">
    <div class="top-three">
      <h2 id="top-three-heading">Top 3 this week</h2>
      {
        topThree.length > 0 ? (
          <ol>
            {topThree.map((t) => (
              <li>{t}</li>
            ))}
          </ol>
        ) : fallbackNote ? (
          <p>{fallbackNote}</p>
        ) : (
          <p class="empty">
            No digests yet — the first will appear after the Routines run.
          </p>
        )
      }
    </div>
  </section>

  {
    hasAnyDigest && (
      <section aria-labelledby="latest-heading">
        <h2 id="latest-heading">Latest digests</h2>
        <div class="card-grid card-grid--three">
          {latestCards.map((entry) => (
            <DigestCard entry={entry} />
          ))}
        </div>
        <p style="margin-top:1rem;">
          <a href={withBase("/archive")}>Browse the full archive →</a>
        </p>
      </section>
    )
  }
</BaseLayout>
